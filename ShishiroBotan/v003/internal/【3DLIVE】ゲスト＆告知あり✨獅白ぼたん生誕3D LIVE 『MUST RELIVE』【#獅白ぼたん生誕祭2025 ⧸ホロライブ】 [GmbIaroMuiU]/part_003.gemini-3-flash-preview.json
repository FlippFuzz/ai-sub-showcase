        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:16.000",
        "end": "01:19.500",
        "original": "どういたしまして。でもお礼なんていらないって",
        "english": "You're welcome. But I told you, you don't need to thank me.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:19.800",
        "end": "01:21.000",
        "original": "ん？",
