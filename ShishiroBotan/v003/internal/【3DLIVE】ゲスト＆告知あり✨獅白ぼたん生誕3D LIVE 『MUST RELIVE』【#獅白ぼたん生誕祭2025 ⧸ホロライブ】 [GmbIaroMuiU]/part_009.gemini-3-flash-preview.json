        "original": "あなたのかけらだけは",
        "english": "Only your fragments remain",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:40.050",
        "end": "03:44.850",
        "original": "手探りでも かたちをなぞれば",
        "english": "Even if by touch, if I trace the shape",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:45.000",
        "end": "03:48.350",
        "original": "長い眠りの中",
        "english": "In a long sleep",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:49.000",
        "end": "03:55.200",
        "original": "あなたを 夢見るでしょう",
        "english": "I will probably dream of you",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:55.550",
        "end": "03:59.700",
        "original": "ふたり 見慣れたあの時間を何度でも",
        "english": "The two of us, those familiar times over and over",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:00.000",
        "end": "04:05.400",
        "original": "夜明けは あなたにだけ",
        "english": "The dawn is for you alone",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:05.850",
        "end": "04:11.450",
        "original": "空には もう果てがないから",
        "english": "Because there's no end to the sky anymore",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:23.600",
        "end": "04:29.850",
        "original": "なにを求めたのか 遠い日のわたしに今",
        "english": "What did I seek? To my former self, now",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:30.000",
        "end": "04:33.300",
        "original": "問いかけ",
        "english": "I ask",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:33.950",
        "end": "04:41.350",
        "original": "砕かれ色褪せ落ちていく あの",
        "english": "Broken, faded, falling...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:41.950",
        "end": "04:45.850",
        "original": "かけらたちはどこへ",
        "english": "Where are those fragments going?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      }
