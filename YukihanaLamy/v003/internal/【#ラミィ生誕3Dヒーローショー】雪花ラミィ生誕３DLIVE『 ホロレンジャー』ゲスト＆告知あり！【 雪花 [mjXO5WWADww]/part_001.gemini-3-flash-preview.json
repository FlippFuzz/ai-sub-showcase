        "type": "dialogue"
      },
      {
        "start": "03:09.000",
        "end": "03:13.500",
        "original": "そして、今年のラミィは一味違います！",
        "english": "And this year, Lamy is a bit different!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
