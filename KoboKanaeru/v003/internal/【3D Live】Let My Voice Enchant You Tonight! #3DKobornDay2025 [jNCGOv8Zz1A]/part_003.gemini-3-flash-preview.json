        "type": "dialogue"
      },
      {
        "start": "03:19.900",
        "end": "03:20.600",
        "original": "え？",
        "english": "Eh?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:20.600",
        "end": "03:21.900",
        "original": "イブリス dari mana?",
        "english": "Where are you from, demon?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:21.900",
        "end": "03:24.900",
        "original": "Wah, dikatain orang iblis, wah wah.",
        "english": "Wow, being called a demon by someone, wow wow.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:24.900",
        "end": "03:25.600",
        "original": "Wahai!",
        "english": "Hey!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:26.600",
        "end": "03:29.900",
        "original": "Itu empat tanduk bahaya sekali.",
        "english": "Those four horns are very dangerous.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:30.900",
        "end": "03:33.300",
        "original": "Iya, jadi gini...",
        "english": "Yeah, so the thing is...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:33.300",
        "end": "03:35.900",
        "original": "Aku datang jauh-jauh...",
        "english": "I've come from far away...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:35.900",
        "end": "03:37.300",
        "original": "Ya, jauh-jauh...",
        "english": "Yeah, from far away...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:37.300",
        "end": "03:39.900",
        "original": "Apa? Meskipun tidak diundang?",
        "english": "What? Even though you weren't invited?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:39.900",
        "end": "03:40.900",
        "original": "Ah, diundang!",
        "english": "Ah, I was invited!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:40.900",
        "end": "03:44.300",
        "original": "Iya, kayaknya kamu ngundang yang lain deh tadi.",
        "english": "Yeah, it seems like you invited someone else earlier.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:44.300",
        "end": "03:45.900",
        "original": "Ma... ma... maksudnya?",
        "english": "Wh... wh... what do you mean?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:45.900",
        "end": "03:47.300",
        "original": "どういう意味？",
        "english": "What do you mean?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:47.300",
        "end": "03:49.900",
        "original": "Kenapa tiba-tiba 日本語？",
        "english": "Why suddenly Japanese?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:50.900",
        "end": "03:53.300",
        "original": "Kamu malaikat Jepang ya?",
        "english": "Are you a Japanese angel?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:53.300",
        "end": "03:56.600",
        "original": "Bisa berhenti muter? Pusing.",
        "english": "Can you stop spinning? I'm dizzy.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:56.600",
        "end": "03:57.300",
        "original": "Pusing?",
        "english": "Dizzy?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:57.300",
        "end": "03:58.600",
        "original": "Ya udah dah dah.",
        "english": "Okay then, bye-bye.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:58.600",
        "end": "04:00.600",
        "original": "Aduh, malaikat kok pusing guys.",
        "english": "Man, how can an angel be dizzy, guys.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:00.600",
        "end": "04:04.600",
        "original": "Iya, aku di sini soalnya datang buat ngerayu kamu aja sebenarnya.",
        "english": "Yeah, I'm here because I actually came to seduce you.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:04.600",
        "end": "04:06.600",
        "original": "Pengen main bareng, pengen godain kamu aja.",
        "english": "I want to play together, I just want to tease you.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:07.300",
        "end": "04:10.300",
        "original": "Sini sini sini...!",
        "english": "Come here, come here, come here...!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:10.300",
        "end": "04:13.300",
        "original": "Pulang kamu habis ini. Loh, kamu habis ini pulang sama aku kan?",
        "english": "Go home after this. Eh, you're going home with me after this, right?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:13.300",
        "end": "04:14.300",
        "original": "Pulang?",
        "english": "Go home?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:14.300",
        "end": "04:16.600",
        "original": "Iya, habis ini nggak ada apa-apa lagi kan?",
        "english": "Yeah, there's nothing else after this, right?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:16.600",
        "end": "04:19.300",
        "original": "Ngapain enak-enak aku di atas.",
        "english": "Why am I having such a good time up here.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:19.300",
        "end": "04:22.300",
        "original": "Masa kamu seret aku?",
        "english": "Are you going to drag me?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:22.300",
        "end": "04:24.300",
        "original": "Loh, loh, kita...",
        "english": "Eh, eh, we...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:24.300",
        "end": "04:27.300",
        "original": "Kita, kita, lo aja iblis!",
        "english": "We, we, you're the one who's a demon!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:30.300",
        "end": "04:31.300",
        "original": "Ajak dong!",
        "english": "Invite me then!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:31.300",
        "end": "04:32.600",
        "original": "Ajak dong banget!",
        "english": "Invite me so much!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:32.600",
        "end": "04:34.300",
        "original": "Kamu saya ajak.",
        "english": "I'll invite you.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:34.300",
        "end": "04:36.300",
        "original": "Aku kesepian.",
        "english": "I'm lonely.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:36.300",
        "end": "04:37.300",
        "original": "Ayo sini bareng.",
        "english": "Come here with me.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:38.300",
        "end": "04:39.900",
        "original": "Fallen angel nih!",
        "english": "A fallen angel here!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:39.900",
        "end": "04:42.600",
        "original": "Nggak nggak, nggak ada fallen angel, nggak ada nggak ada.",
        "english": "No no, there's no fallen angel, none at all.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:43.600",
        "end": "04:45.300",
        "original": "Eits, nih aku panah.",
        "english": "Eits, I'll shoot you.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:45.300",
        "end": "04:46.600",
        "original": "Iya iya.",
        "english": "Yeah yeah.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:46.600",
        "end": "04:47.300",
        "original": "Coba coba.",
        "english": "Try it.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:47.300",
        "end": "04:48.300",
        "original": "Panah asmara!",
        "english": "Arrow of love!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:48.300",
        "end": "04:49.300",
        "original": "Satu, dua, tiga!",
        "english": "One, two, three!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:52.300",
        "end": "04:53.300",
        "original": "Ya iya!",
        "english": "Yes yes!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:53.300",
        "end": "04:55.300",
        "original": "Wah gila gila!",
        "english": "Wow, crazy crazy!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:55.900",
        "end": "04:58.300",
        "original": "How to tame your demon.",
        "english": "How to tame your demon.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:58.600",
        "end": "05:00.600",
        "original": "Jadi light novel.",
        "english": "It's become a light novel.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      }
    ],
    "model_name": "gemini-3-flash-preview"
  }
