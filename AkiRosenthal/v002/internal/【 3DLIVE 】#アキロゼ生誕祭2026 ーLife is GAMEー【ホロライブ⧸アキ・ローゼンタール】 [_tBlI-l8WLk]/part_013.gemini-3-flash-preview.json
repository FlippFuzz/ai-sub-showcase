        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:09.100",
        "end": "00:10.800",
        "original": "お楽しみに！",
        "english": "Look forward to it!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:11.300",
        "end": "00:13.800",
        "original": "そして、お知らせ3つ目！",
