    "subtitles": [
      {
        "start": "00:00.000",
        "end": "00:01.200",
        "original": "…だけよ",
        "english": "…just that.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:01.200",
        "end": "00:04.200",
        "original": "何も感じず過ごせばいいの",
        "english": "I should just spend my time feeling nothing.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:04.200",
        "end": "00:07.500",
        "original": "戸惑う言葉与えられても",
        "english": "Even if I'm given confusing words,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:07.500",
        "end": "00:10.900",
        "original": "自分の心ただ上の空",
        "english": "My heart remains absent-minded.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:10.900",
        "end": "00:14.300",
        "original": "もし私から動くのならば",
        "english": "If I were to move on my own,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:14.300",
        "end": "00:18.000",
        "original": "すべて変えるのなら黒にする",
        "english": "If I change everything, I'll turn it black.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:18.000",
        "end": "00:21.500",
        "original": "動くのならば　動くのならば",
        "english": "If I move, if I move,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:21.500",
        "end": "00:25.100",
        "original": "すべて壊すわ　すべて壊すわ",
        "english": "I'll destroy everything, I'll destroy everything.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:25.100",
        "end": "00:28.800",
        "original": "悲しむならば　悲しむならば",
        "english": "If I grieve, if I grieve,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:28.800",
        "end": "00:32.400",
        "original": "私の心　白く変われば",
        "english": "If my heart turns white,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:32.400",
        "end": "00:36.000",
        "original": "あなたのことも　私のことも",
        "english": "Even you, even me,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:36.000",
        "end": "00:39.600",
        "original": "すべてのことも　まだ知らないの",
        "english": "And everything else... I still don't know.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:39.600",
        "end": "00:43.100",
        "original": "重い目蓋を開けたのならば",
        "english": "If I open my heavy eyelids,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:43.100",
        "end": "00:46.500",
        "original": "すべて壊すのなら黒になれ",
        "english": "If I'm to destroy everything, turn black!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:42.100",
        "end": "01:47.800",
        "original": "いつか君が瞳に灯す愛の光が",
        "english": "Someday, the light of love you kindle in your eyes",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:47.800",
        "end": "01:50.000",
        "original": "時を超えて",
        "english": "Will transcend time,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:50.000",
        "end": "01:54.000",
        "original": "滅び急ぐ世界の夢を",
        "english": "The dream of a world rushing to ruin,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:54.000",
        "end": "01:55.300",
        "original": "確かに一つ",
        "english": "Surely, one thing,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:55.300",
        "end": "01:57.200",
        "original": "壊すだろう",
        "english": "Will destroy it.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:57.200",
        "end": "01:59.800",
        "original": "躊躇いを飲み干して",
        "english": "Swallowing down hesitation,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:59.800",
        "end": "02:04.000",
        "original": "君が望むものは何？",
        "english": "What is it that you desire?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:04.000",
        "end": "02:08.000",
        "original": "こんな欲深い憧れの行方に",
        "english": "At the destination of such greedy longing,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:08.000",
        "end": "02:12.800",
        "original": "儚い明日はあるの？",
        "english": "Is there a fleeting tomorrow?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:14.500",
        "end": "02:18.000",
        "original": "子供の頃夢に見てた",
        "english": "I saw it in my dreams as a child,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:18.000",
        "end": "02:22.000",
        "original": "古の魔法のように",
        "english": "Like ancient magic,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:22.000",
        "end": "02:26.000",
        "original": "闇さえ砕く力で",
        "english": "With power to smash even darkness,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:26.000",
        "end": "02:29.800",
        "original": "微笑む君に会いたい",
        "english": "I want to see you smiling.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:29.800",
        "end": "02:34.000",
        "original": "怯えるこの手の中には",
        "english": "Inside these trembling hands,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:34.000",
        "end": "02:37.800",
        "original": "手折られた花と勇気",
        "english": "A plucked flower and courage.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:37.800",
        "end": "02:41.200",
        "original": "想いだけが頼るすべて",
        "english": "My feelings are the only thing I rely on,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:41.200",
        "end": "02:45.000",
        "original": "光を呼び覚ます",
        "english": "Awakening the light,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:45.000",
        "end": "02:48.000",
        "original": "願い",
        "english": "A wish.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:55.000",
        "end": "02:59.000",
        "original": "いつか君も誰かの為に",
        "english": "Someday, you too, for someone's sake,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:59.000",
        "end": "03:02.000",
        "original": "強い力を望むのだろう",
        "english": "Will wish for strong power.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:02.000",
        "end": "03:06.000",
        "original": "愛が胸を捉えた夜に",
        "english": "On the night love seized your heart,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:06.000",
        "end": "03:09.500",
        "original": "未知の言葉が生まれて来る",
        "english": "Unknown words will be born.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:09.500",
        "end": "03:13.500",
        "original": "迷わずに行けるなら",
        "english": "If I can go without wavering,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:13.500",
        "end": "03:17.000",
        "original": "心が砕けてもいいわ",
        "english": "I don't mind if my heart breaks.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:17.000",
        "end": "03:20.500",
        "original": "いつも目の前の悲しみに",
        "english": "To face the sadness always before my eyes,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:20.500",
        "end": "03:23.500",
        "original": "立ち向かう為の",
        "english": "I want a spell...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:23.500",
        "end": "03:26.500",
        "original": "呪文が欲しい",
        "english": "...to stand against it.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:27.500",
        "end": "03:31.000",
        "original": "君はまだ夢見る記憶",
        "english": "You are a memory still dreaming,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:31.000",
        "end": "03:34.800",
        "original": "私は眠らない明日",
        "english": "I am a sleepless tomorrow.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:34.800",
        "end": "03:38.800",
        "original": "二人が出会う奇跡を",
        "english": "To win the miracle of us meeting,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:38.800",
        "end": "03:42.500",
        "original": "勝ち取る為に進むわ",
        "english": "I will move forward.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:42.500",
        "end": "03:46.500",
        "original": "怯えるこの手の中には",
        "english": "Inside these trembling hands,",
        "alignment_source": "audio_tokens",
