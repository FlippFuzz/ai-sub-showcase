      },
      {
        "start": "03:50.000",
        "end": "03:53.800",
        "original": "想いだけが生きるすべて",
        "english": "My feelings are all that live,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:53.800",
