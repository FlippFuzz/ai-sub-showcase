      },
      {
        "start": "03:41.500",
        "end": "03:43.000",
        "original": "Yeah?",
        "english": "Yeah?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:43.000",
        "end": "03:45.000",
        "original": "Oh, yeah. I mean, yeah, obviously yeah.",
        "english": "Oh, yeah. I mean, yeah, obviously yeah.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:45.000",
        "end": "03:46.500",
