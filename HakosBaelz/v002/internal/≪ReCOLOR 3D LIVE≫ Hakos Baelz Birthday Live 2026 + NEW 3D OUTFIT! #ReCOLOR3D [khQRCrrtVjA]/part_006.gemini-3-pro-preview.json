        "original": "It's so cool!",
        "english": "It's so cool!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:49.200",
        "end": "03:51.500",
        "original": "You look like a K-pop star.",
        "english": "You look like a K-pop star.",
        "alignment_source": "audio_tokens",
