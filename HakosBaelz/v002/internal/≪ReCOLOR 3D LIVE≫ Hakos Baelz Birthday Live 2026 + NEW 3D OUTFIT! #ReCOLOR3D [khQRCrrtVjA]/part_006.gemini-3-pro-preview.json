        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:23.200",
        "end": "03:25.000",
        "original": "Here to rumble!",
        "english": "Here to rumble!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:25.000",
        "end": "03:26.500",
        "original": "Yeah!",
        "english": "Yeah!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:26.500",
        "end": "03:28.500",
        "original": "What's this movement?",
        "english": "What's this movement?",
