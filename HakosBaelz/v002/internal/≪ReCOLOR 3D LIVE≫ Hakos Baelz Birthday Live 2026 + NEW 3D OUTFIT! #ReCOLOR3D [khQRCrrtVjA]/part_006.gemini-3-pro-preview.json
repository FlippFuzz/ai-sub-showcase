        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:04.200",
        "end": "03:05.500",
        "original": "Ah, introduce yourselves please.",
        "english": "Ah, introduce yourselves please.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:05.500",
        "end": "03:07.500",
        "original": "Please go ahead.",
        "english": "Please go ahead.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:07.500",
        "end": "03:10.500",
        "original": "HoloLive English CHAD CASTの森カリオペです！",
        "english": "It's Mori Calliope from HoloLive English CHAD CAST!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:10.500",
        "end": "03:12.500",
        "original": "What's up? ですです！",
        "english": "What's up? Desu desu!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:12.500",
        "end": "03:13.500",
        "original": "Hey guys!",
        "english": "Hey guys!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:13.500",
        "end": "03:15.500",
        "original": "Hope you enjoyed our performances!",
        "english": "Hope you enjoyed our performances!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:15.500",
        "end": "03:17.000",
        "original": "Yeah! And...",
        "english": "Yeah! And...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:17.000",
