        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:58.500",
        "end": "04:00.500",
        "original": "I gotta put it to rest for a little bit.",
        "english": "I gotta put it to rest for a little bit.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:00.500",
        "end": "04:02.500",
        "original": "You know, after all that dancing.",
        "english": "You know, after all that dancing.",
