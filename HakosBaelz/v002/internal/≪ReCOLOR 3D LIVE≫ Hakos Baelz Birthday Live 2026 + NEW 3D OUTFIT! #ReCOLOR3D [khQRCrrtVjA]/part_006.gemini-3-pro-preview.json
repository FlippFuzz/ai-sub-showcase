        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:18.500",
        "end": "03:20.500",
        "original": "Also from CHAD CAST!",
        "english": "Also from CHAD CAST!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:20.500",
        "end": "03:21.800",
        "original": "Yeah, let's go!",
