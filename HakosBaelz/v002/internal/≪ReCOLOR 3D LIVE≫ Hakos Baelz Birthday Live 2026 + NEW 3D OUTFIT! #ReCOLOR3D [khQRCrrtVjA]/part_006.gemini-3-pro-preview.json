        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:34.500",
        "end": "03:36.500",
        "original": "It's a big day, guys.",
        "english": "It's a big day, guys.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:36.500",
        "end": "03:38.000",
        "original": "'Cause you're dancing.",
        "english": "'Cause you're dancing.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:38.000",
        "end": "03:40.000",
        "original": "Yeah. It's a big day.",
        "english": "Yeah. It's a big day.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:40.000",
        "end": "03:41.500",
        "original": "Guys!",
