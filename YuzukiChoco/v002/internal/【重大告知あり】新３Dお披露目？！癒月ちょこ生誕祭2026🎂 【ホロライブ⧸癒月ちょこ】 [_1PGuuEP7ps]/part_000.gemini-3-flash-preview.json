        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:35.050",
        "end": "03:37.450",
        "original": "ときめき運んで Step My You",
        "english": "So bring me excitement, Step My You",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:37.750",
