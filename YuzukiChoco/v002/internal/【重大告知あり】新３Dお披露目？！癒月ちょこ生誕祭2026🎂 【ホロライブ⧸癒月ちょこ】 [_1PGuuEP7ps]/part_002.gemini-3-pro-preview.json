      },
      {
        "start": "03:47.700",
        "end": "03:48.800",
        "original": "素晴らしい！",
        "english": "Wonderful!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:48.800",
        "end": "03:51.300",
        "original": "え、じゃあ団長もいいですか？",
