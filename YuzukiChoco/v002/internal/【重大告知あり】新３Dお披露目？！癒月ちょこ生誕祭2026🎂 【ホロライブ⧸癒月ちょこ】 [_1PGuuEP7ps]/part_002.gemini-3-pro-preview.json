        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:51.300",
        "end": "03:52.400",
        "original": "なに、なに、なに？",
        "english": "What, what, what?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:52.400",
        "end": "03:55.300",
        "original": "お尻フリフリ、ちょっとしていただきたいんで。",
