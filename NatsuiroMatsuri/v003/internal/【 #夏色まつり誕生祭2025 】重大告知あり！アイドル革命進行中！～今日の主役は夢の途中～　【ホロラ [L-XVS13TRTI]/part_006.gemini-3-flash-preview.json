        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:14.000",
        "end": "02:17.000",
        "original": "ABCDEFGHIJKLMNOP Poppin'",
        "english": "ABCDEFGHIJKLMNOP Poppin'",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:17.700",
        "end": "02:20.700",
        "original": "Be Poppin'! Poppin'! Poppin'! Poppin'!",
        "english": "Be Poppin'! Poppin'! Poppin'! Poppin'!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:20.700",
        "end": "02:23.300",
        "original": "ぱ！ぱ！ぱ！ぱ！",
        "english": "Pa! Pa! Pa! Pa!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:23.700",
        "end": "02:24.400",
        "original": "最大級 最高級 最上級",
        "english": "Greatest, highest, superlative",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:24.400",
        "end": "02:26.600",
        "original": "ハイスペックな人生です",
        "english": "A high-spec life",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:26.600",
        "end": "02:27.400",
        "original": "アイラブユー アイフォーユー",
        "english": "I love you, I for you",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:27.400",
        "end": "02:29.600",
        "original": "だけど君がいないと寂しいな",
        "english": "But it's lonely without you",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:29.600",
        "end": "02:30.300",
        "original": "ほんとはね やっぱりね",
        "english": "Actually, you see, after all",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:30.300",
        "end": "02:31.100",
        "original": "結局ね ずっとこうやって",
        "english": "In the end, keep going like this",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:31.100",
        "end": "02:33.700",
        "original": "ぱぴぷぺぽな感じでポップに生きていこう",
        "english": "Living life in a 'Pa-pi-pu-pe-po' kind of way",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:37.000",
        "end": "02:38.500",
        "original": "ぱぴぷぺぽ",
        "english": "Pa-pi-pu-pe-po",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:38.500",
        "end": "02:39.200",
        "original": "ぴゅんぴゅんです ぴゅんぴゅんです",
        "english": "Pyun-pyun! Pyun-pyun!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:39.200",
        "end": "02:40.000",
        "original": "るんるんです きゃっきゃーです",
        "english": "Run-run! Kyah-kyah!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:40.000",
        "end": "02:40.700",
        "original": "ハッピーです",
        "english": "I'm happy",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:40.700",
        "end": "02:41.400",
        "original": "問題ないっす 半端ないっす",
        "english": "No problem, it's incredible",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:41.400",
        "end": "02:43.300",
        "original": "我々ディスコティックなバンビーナ",
        "english": "We're discotheque bambinas",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:44.800",
        "end": "02:45.500",
        "original": "テキトーです イージーです",
        "english": "Going with the flow, it's easy",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:45.500",
        "end": "02:46.300",
        "original": "曖昧です ずっとこうやって",
        "english": "It's ambiguous, keep going like this",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:46.300",
        "end": "02:48.900",
        "original": "ぱぴぷぺぽな感じでポップに生きていこう",
        "english": "Living life in a 'Pa-pi-pu-pe-po' kind of way",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:53.300",
        "end": "02:54.800",
        "original": "ポップにエンジョイ",
        "english": "Enjoy in a pop way",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:54.800",
        "end": "02:56.300",
        "original": "あれこれどれそれ楽しいね",
        "english": "This and that, everything is fun",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:57.000",
        "end": "02:57.800",
        "original": "Hi!",
        "english": "Hi!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:57.800",
        "end": "02:58.500",
        "original": "Hi! Hi!",
        "english": "Hi! Hi!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:58.500",
        "end": "03:00.000",
        "original": "ポップにエンジョイ",
        "english": "Enjoy in a pop way",
        "alignment_source": "audio_tokens",
