      },
      {
        "start": "03:00.000",
        "end": "03:01.400",
        "original": "あれこれどれそれ楽しいね",
        "english": "This and that, everything is fun",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:02.200",
        "end": "03:03.000",
        "original": "Hi!",
        "english": "Hi!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:03.000",
        "end": "03:03.700",
        "original": "Hi! Hi!",
        "english": "Hi! Hi!",
        "alignment_source": "audio_tokens",
