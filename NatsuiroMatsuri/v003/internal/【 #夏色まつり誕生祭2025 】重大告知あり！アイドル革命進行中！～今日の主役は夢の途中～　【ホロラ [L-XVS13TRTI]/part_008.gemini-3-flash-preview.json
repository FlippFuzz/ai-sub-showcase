        "original": "カプセラ",
        "english": "Capsella",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:07.200",
        "end": "04:10.900",
        "original": "君に恋々恋のエスオーエス",
        "english": "Love-love-loving you, SOS",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:10.900",
        "end": "04:14.900",
        "original": "ずっと胸が苦しいんです",
        "english": "My heart has been aching this whole time",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:14.900",
        "end": "04:19.000",
        "original": "早くレスキュー好きのテレパシーに",
        "english": "Quick, rescue me, through the telepathy of love",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:19.000",
        "end": "04:21.800",
        "original": "早く気づいて",
        "english": "Please notice quickly",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:23.000",
        "end": "04:26.000",
        "original": "SOS\n作曲：睦月周平 / 作詞：下地悠",
        "english": "SOS\nComposition: Shuhei Mutsuki / Lyrics: Yu Shimoji",
        "alignment_source": "visual_inference",
        "type": "on_screen_text"
      },
      {
        "start": "04:38.500",
        "end": "04:41.500",
        "original": "初めて会った時から",
        "english": "From the moment we first met",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:41.500",
        "end": "04:44.700",
        "original": "ハートが震えてたんだよ",
        "english": "My heart was trembling",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:44.700",
        "end": "04:47.900",
        "original": "無意識に意識しちゃう",
        "english": "I'm unconsciously conscious of you",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:47.900",
        "end": "04:52.000",
        "original": "この感じはきっと重症で",
        "english": "This feeling must be a serious case",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:52.000",
