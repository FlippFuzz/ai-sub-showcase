        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:01.850",
        "end": "01:03.450",
        "original": "しのこの言わず さあしてちょうだい",
        "english": "Stop complaining and do it already",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:03.450",
        "end": "01:05.150",
        "original": "待って 一位な天中！",
        "english": "Wait, first place in the heavens!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:05.150",
        "end": "01:06.650",
        "original": "鼻血ブーなのだ",
        "english": "Nosebleed, boo!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:06.650",
        "end": "01:08.350",
        "original": "自分の意思は どんなもんじゃい",
        "english": "What's your own will like?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:08.350",
        "end": "01:10.050",
        "original": "い・い・いいなずきゅん",
        "english": "I-I-Iinazukkyun",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:10.050",
        "end": "01:11.850",
        "original": "I love you なのだ",
        "english": "It's \"I love you\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:11.850",
        "end": "01:13.450",
        "original": "四六時中愛をちょうだい",
        "english": "Give me love all the time",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:13.450",
        "end": "01:15.250",
        "original": "待って 1GPなバッキュン",
        "english": "Wait, 1GP bang",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:15.250",
        "end": "01:17.050",
        "original": "あい、あい、あいはバッキュン",
        "english": "Love, love, love is a bang",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:17.050",
        "end": "01:18.650",
        "original": "1/2（にぶんのいち）がたまんない",
