        "type": "dialogue"
      },
      {
        "start": "01:25.100",
        "end": "01:28.150",
        "original": "風前絶後 天真爛漫",
        "english": "Unprecedented, innocent and cheerful",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:28.200",
        "end": "01:32.400",
        "original": "平愛無常 明鏡止水",
        "english": "Ordinary love is impermanent, clear and serene",
