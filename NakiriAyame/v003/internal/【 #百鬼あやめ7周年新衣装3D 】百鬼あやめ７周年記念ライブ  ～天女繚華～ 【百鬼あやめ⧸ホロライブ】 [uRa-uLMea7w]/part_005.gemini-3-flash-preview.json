        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:18.650",
        "end": "01:21.850",
        "original": "惚れなんて試練 会いたいかも知れん",
        "english": "Falling in love is a trial, I might want to meet",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:21.900",
        "end": "01:25.050",
        "original": "毎晩 競り合い たりないや",
