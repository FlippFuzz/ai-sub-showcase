        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:06.500",
        "end": "04:08.800",
        "original": "ハッとするほど鮮やかな",
        "english": "A world so vivid it takes your breath away",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:08.800",
        "end": "04:12.300",
        "original": "世界があるんだと知った",
        "english": "I learned that it exists",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:13.000",
        "end": "04:15.500",
        "original": "あなたの無理難題に",
        "english": "To your unreasonable demands",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:15.800",
        "end": "04:18.500",
        "original": "応えていくその度に",
        "english": "Every time I respond",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:19.300",
        "end": "04:21.800",
        "original": "アッと言わせるような",
        "english": "Something that leaves you speechless",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:21.800",
        "end": "04:25.000",
        "original": "奇想天外な答え合わせで",
        "english": "With an unexpected answer check",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:25.800",
        "end": "04:28.500",
        "original": "辿り着いたその先に",
        "english": "At the end of that journey",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:28.500",
        "end": "04:31.500",
        "original": "新しい景色が待っているんだ",
        "english": "A new view is waiting",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:38.500",
        "end": "04:41.300",
        "original": "摩訶不思議なミステリー",
        "english": "A mysterious mystery",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:41.500",
        "end": "04:44.500",
        "original": "次から次に起こるたび",
        "english": "Every time they happen one after another",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:45.000",
        "end": "04:47.300",
        "original": "巧妙なからくりも",
        "english": "Even the ingenious tricks",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:47.300",
