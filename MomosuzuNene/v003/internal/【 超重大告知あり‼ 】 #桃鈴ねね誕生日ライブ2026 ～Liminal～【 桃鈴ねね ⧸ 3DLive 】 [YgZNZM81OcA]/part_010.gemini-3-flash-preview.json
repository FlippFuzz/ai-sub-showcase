        "original": "二人 夕暮れの帰り道で",
        "english": "The two of us on the way home at dusk",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:41.200",
        "end": "02:44.200",
        "original": "忘れないよ さよならメモリーズ",
        "english": "I won't forget, goodbye memories",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:44.200",
        "end": "02:47.800",
        "original": "出会えたこと 感謝してる",
        "english": "I'm grateful that we met",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:47.800",
        "end": "02:51.500",
        "original": "初めて見た",
        "english": "I saw for the first time",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:51.500",
        "end": "03:00.000",
        "original": "満開の桜",
        "english": "the cherry blossoms in full bloom",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:00.000",
        "end": "03:05.500",
        "original": "あれからどれくらい",
        "english": "I wonder how much",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:05.500",
