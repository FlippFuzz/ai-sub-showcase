      },
      {
        "start": "00:05.500",
        "end": "00:08.200",
        "original": "続く道",
        "english": "is a road that continues",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:08.200",
        "end": "00:11.800",
        "original": "そんな気がしたの",
        "english": "I felt that way",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:16.800",
        "end": "00:20.500",
        "original": "例年より早い",
        "english": "Earlier than usual",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:20.500",
        "end": "00:25.500",
        "original": "開花予想を",
        "english": "the cherry blossom forecast",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:25.500",
        "end": "00:29.800",
        "original": "君は嬉しがってた",
        "english": "you were happy about it",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:29.800",
        "end": "00:32.400",
        "original": "私は笑って",
        "english": "I laughed",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:32.400",
        "end": "00:34.900",
        "original": "「そうだね」って言った",
        "english": "and said \"That's true\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:34.900",
        "end": "00:41.000",
        "original": "あと少ししたら もうここには戻れないのに",
        "english": "Even though in a little while, I won't be able to return here anymore",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:41.000",
        "end": "00:44.200",
        "original": "言葉じゃうまく言えない想いを",
        "english": "The feelings I can't quite put into words",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:44.200",
        "end": "00:46.900",
        "original": "君に打ち明けるとしたらなんて",
        "english": "if I were to reveal them to you...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:46.900",
        "end": "00:50.100",
        "original": "伝えよう",
        "english": "I'll tell you",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:50.100",
        "end": "00:53.000",
        "original": "最初で最後",
        "english": "for the first and last time",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:53.000",
        "end": "00:56.500",
        "original": "いつか一緒に帰った道は",
        "english": "The road we once walked home together on",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:56.500",
        "end": "01:00.000",
        "original": "私にとって特別な思い出",
        "english": "is a special memory for me",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:00.000",
        "end": "01:03.200",
        "original": "忘れないよ さよならメモリーズ",
        "english": "I won't forget, goodbye memories",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:03.200",
        "end": "01:05.100",
        "original": "春が来たら それぞれの道を",
        "english": "When spring comes, we'll go our separate ways",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:23.500",
        "end": "01:27.500",
        "original": "また会える日を願って",
        "english": "Wishing for the day we meet again",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:27.500",
        "end": "01:30.500",
        "original": "さよなら",
        "english": "Goodbye",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:30.500",
        "end": "01:33.200",
        "original": "小さくつぶやいた",
        "english": "I whispered softly",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:35.500",
        "end": "01:40.800",
        "original": "空はあの日と変わらず",
        "english": "The sky is as blue as it was that day",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:40.800",
        "end": "01:43.700",
        "original": "青くて",
        "english": "and so",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:43.700",
        "end": "01:50.000",
        "original": "だからちょっと泣けた",
        "english": "I cried a little",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:52.000",
        "end": "01:57.000",
        "original": "わざと遠回りしたの",
        "english": "I took the long way on purpose",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:57.000",
        "end": "02:04.600",
        "original": "少しでも長く君の隣にいたくて",
        "english": "Wanting to be by your side just a little longer",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:04.600",
        "end": "02:07.500",
        "original": "私はおどけて",
        "english": "I joked around",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:07.500",
        "end": "02:11.200",
        "original": "「間違えた」って言った",
        "english": "and said \"I took the wrong way\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:11.200",
        "end": "02:14.600",
        "original": "君が笑うその顔がまぶしくて",
        "english": "Your smiling face was so bright",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:14.600",
        "end": "02:17.300",
        "original": "目をそらした",
        "english": "that I looked away",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:17.300",
        "end": "02:22.600",
        "original": "言葉じゃうまく言えない想いを胸に抱いて",
        "english": "Clutching the feelings I can't put into words to my chest",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:22.600",
        "end": "02:29.000",
        "original": "この道を歩いた",
        "english": "I walked this road",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:29.000",
        "end": "02:32.400",
        "original": "覚えてる あの時君は",
        "english": "I remember, back then",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:32.400",
        "end": "02:35.300",
        "original": "私の名前を呼んでくれた",
        "english": "you called my name",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:35.300",
