        "original": "なんでかな",
        "english": "I wonder why",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:44.200",
        "end": "03:47.300",
        "original": "わかんないよ",
        "english": "I don't know",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:47.300",
        "end": "03:52.500",
        "original": "それからの毎日を とても楽しくて",
        "english": "Every day since then has been so much fun",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:52.500",
        "end": "03:59.400",
        "original": "だけど同じくらい辛かったんだ",
        "english": "but just as painful",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:59.400",
        "end": "04:02.400",
        "original": "ごめんね なんかうまく言えないよ",
        "english": "I'm sorry, I can't say it well",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:02.400",
        "end": "04:07.800",
        "original": "だから私 君となんていうか",
        "english": "So, I... with you... how should I say it...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:07.800",
        "end": "04:12.300",
        "original": "今のままさよならしたくないの",
        "english": "I don't want to say goodbye as things are now",
        "alignment_source": "audio_tokens",
