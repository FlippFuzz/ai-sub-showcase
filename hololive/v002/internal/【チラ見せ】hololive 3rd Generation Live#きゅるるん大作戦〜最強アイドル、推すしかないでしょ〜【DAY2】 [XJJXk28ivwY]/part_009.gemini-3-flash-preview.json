      {
        "start": "01:00.700",
        "end": "01:03.400",
        "original": "DAY2！",
        "english": "Day 2!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:03.450",
        "end": "01:06.350",
        "original": "DAY2ですよ！",
        "english": "It's Day 2!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:06.400",
        "end": "01:08.700",
        "original": "DAY2だー！",
        "english": "It's Day 2!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:09.950",
        "end": "01:12.100",
        "original": "じゃあ早速自己紹介からしていきますか？",
        "english": "Shall we start with the introductions right away?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:12.150",
        "end": "01:13.800",
        "original": "していきましょう！",
        "english": "Let's do it!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:13.850",
        "end": "01:14.650",
        "original": "はい！",
        "english": "Okay!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:14.700",
        "end": "01:18.900",
        "original": "じゃあみんな、ぺこら久しぶりのあの挨拶行くから",
        "english": "Then everyone, Pekora's going to do her long-awaited signature greeting,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:18.950",
        "end": "01:21.050",
        "original": "分かるよねみんな？　あの挨拶だよ！",
        "english": "you all know it, right? It's that greeting!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:21.100",
        "end": "01:22.450",
        "original": "どの挨拶だ？",
        "english": "Which one is it?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:22.500",
        "end": "01:23.250",
        "original": "あれだ！",
        "english": "That one!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:23.300",
        "end": "01:24.350",
        "original": "あれしかない！",
        "english": "It can only be that one!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:24.400",
        "end": "01:25.250",
        "original": "いくぞー！",
        "english": "Here I go!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:25.300",
        "end": "01:27.700",
        "original": "ドドンガドンドン、全人類Vチューバー、",
        "english": "Dodonga don don, for all humanity V-Tuber,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:27.750",
        "end": "01:30.900",
        "original": "全人、全V...　ドドン...　大丈夫か！？",
        "english": "all huma, all V... Dodon... Are you okay?!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:31.950",
        "end": "01:33.400",
        "original": "もう一回、もう一回ね！",
        "english": "One more time, one more time!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:33.450",
        "end": "01:34.900",
        "original": "もう一度ね！",
        "english": "One more try!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:34.950",
        "end": "01:35.800",
        "original": "行きます！",
        "english": "Here I go!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:35.850",
        "end": "01:38.900",
        "original": "ドドンガドンドン、全Vチューバー一",
        "english": "Dodonga don don, who is the number one",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:38.950",
        "end": "01:42.150",
        "original": "超絶可愛いのは誰だ！？　ドドンガドンドン！",
        "english": "super cute V-Tuber of all?! Dodonga don don!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:42.200",
        "end": "01:44.750",
        "original": "ぺこらちゃーん！",
        "english": "Pekora-chan!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:45.300",
        "end": "01:46.850",
        "original": "やっとできましたー！",
        "english": "I finally did it!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:46.900",
        "end": "01:48.000",
        "original": "ありがとー！",
        "english": "Thank you!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:48.050",
        "end": "01:49.100",
        "original": "はい！",
        "english": "Okay!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:49.950",
        "end": "01:51.350",
        "original": "じゃあ次はフレアちゃん！",
        "english": "Next up is Flare-chan!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:51.400",
        "end": "01:54.600",
        "original": "はい！　じゃあフレアは「はいダーリン！」って言うので",
        "english": "Okay! I'll say \"Hi Darling!\",",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:54.650",
        "end": "01:57.700",
        "original": "「はいハニー！」って返してください！　オッケー？",
        "english": "so please respond with \"Hi Honey!\" Okay?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:59.950",
        "end": "02:02.300",
        "original": "行きますよー！　はいダーリン！",
        "english": "Here I go! Hi Darling!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:02.350",
        "end": "02:04.900",
        "original": "はいハニー！",
        "english": "Hi Honey!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:04.950",
        "end": "02:06.100",
        "original": "ありがとー！",
        "english": "Thank you!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:06.150",
        "end": "02:08.850",
        "original": "ホロライブ3期生、不知火フレアです！",
        "english": "I'm Shiranui Flare from Hololive 3rd Gen!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:08.900",
        "end": "02:09.950",
        "original": "そして？",
        "english": "And next?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:11.100",
        "end": "02:13.200",
        "original": "はい！　えー、どうしようかな今日...",
        "english": "Yes! Um, what should I do today...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:13.250",
        "end": "02:15.900",
        "original": "あ、じゃあ「こんまっする」って言うから普通に「こんまっする」で...",
        "english": "Oh, I'll say \"Konmassuru\", so just say \"Konmassuru\" back...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:15.950",
        "end": "02:17.650",
        "original": "「こんまっする」でいいのか？",
        "english": "Is \"Konmassuru\" good enough?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:17.700",
        "end": "02:19.450",
        "original": "いや、牛丼もね...",
        "english": "Well, beef bowls too...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:19.500",
        "end": "02:21.050",
        "original": "牛丼は、まあまあ...",
        "english": "Beef bowls are... okay, I guess...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:21.100",
        "end": "02:22.400",
        "original": "あ、やばい、やばい！",
        "english": "Oh no, oh no!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:22.450",
        "end": "02:26.700",
        "original": "あばあばあばあば...",
        "english": "Aba-aba-aba-aba...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:26.750",
        "end": "02:28.050",
        "original": "よし、行くぞ！",
        "english": "Alright, here I go!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:28.100",
        "end": "02:30.200",
        "original": "せーの、こんまっするー！",
        "english": "Ready, set... Konmassuru!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:30.250",
        "end": "02:33.700",
        "original": "こんまっするー！",
        "english": "Konmassuru!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:34.300",
        "end": "02:37.350",
        "original": "はい！　ホロライブ3期生の白銀ノエルです！",
        "english": "Yes! I'm Shirogane Noel from Hololive 3rd Gen!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:37.400",
        "end": "02:39.950",
        "original": "よいしょー！　はい！　そして？",
        "english": "Yoisho! Yes! And next?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:42.500",
        "end": "02:46.800",
        "original": "君たち！　本物のパイパイ仮面は誰！？",
        "english": "You guys! Who is the real Pai Pai Mask?!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:46.850",
        "end": "02:49.250",
        "original": "マリンー！",
        "english": "Marine!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:50.150",
        "end": "02:53.600",
        "original": "なんかマリン、一度も言ってないけど",
        "english": "Even though Marine hasn't said it once,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:53.650",
        "end": "02:56.100",
        "original": "パイパイ仮面、パイパイ仮面って...",
        "english": "everyone is shouting \"Pai Pai Mask, Pai Pai Mask\"...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:56.150",
        "end": "02:59.200",
        "original": "なんか昨日からさ、ぺこらに船長取られるし",
        "english": "Since yesterday, Pekora took the title of Captain,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:59.250",
        "end": "03:03.100",
        "original": "ノエルにパイパイ仮面取られるし、本物のパイパイ仮面なんだけどな！",
        "english": "and Noel took the Pai Pai Mask, even though I'm the real one!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:03.150",
        "end": "03:06.100",
        "original": "本物のパイパイ仮面として暴れたいわけですね！",
        "english": "So you want to go wild as the real Pai Pai Mask!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:06.150",
        "end": "03:08.500",
        "original": "悲しい。ということでね！",
        "english": "How sad. So, anyway!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:08.550",
        "end": "03:12.750",
        "original": "はーい、あほーい！　ホロライブ3期生宝鐘海賊団船長の宝鐘マリンです！",
        "english": "Ahoy! I'm the Captain of the Houshou Pirates, Houshou Marine from Hololive 3rd Gen!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:16.150",
        "end": "03:18.900",
        "original": "いや、ついにDAY2！",
        "english": "Wow, finally Day 2!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:18.950",
        "end": "03:20.900",
        "original": "DAY2ですよ！",
        "english": "It's Day 2!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:20.950",
        "end": "03:23.250",
        "original": "なんか昨日と衣装違くない？",
        "english": "Doesn't our outfit look different from yesterday?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:23.300",
        "end": "03:24.400",
        "original": "ね！",
        "english": "Right!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:24.450",
        "end": "03:26.550",
        "original": "あれ、分かりましたか皆さん！",
        "english": "Oh, did everyone notice!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:26.600",
        "end": "03:28.450",
        "original": "なんか昨日とちょっと...",
        "english": "It's a bit different from yesterday...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:28.500",
        "end": "03:29.400",
        "original": "悪魔になっちゃった！",
        "english": "We've become devils!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:29.450",
        "end": "03:32.400",
        "original": "あら！　天使から悪魔っぽくなってしまったかな？",
        "english": "Oh! Have we turned from angels to devilish ones?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:33.450",
        "end": "03:34.900",
        "original": "そうなんですよね！",
        "english": "That's right!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:34.950",
        "end": "03:38.150",
        "original": "実はこれ、初めて公開するんですよね！",
        "english": "Actually, this is the first time we're revealing this!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:38.200",
        "end": "03:39.150",
        "original": "そうなんですよ！",
        "english": "Yes, it is!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:39.200",
        "end": "03:41.200",
        "original": "みんなびっくりしたかな？",
        "english": "I wonder if everyone was surprised?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:41.250",
        "end": "03:43.300",
        "original": "可愛ーい！",
        "english": "So cute!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:43.350",
        "end": "03:45.900",
        "original": "可愛ーい！　ありがとー！",
        "english": "So cute! Thank you!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:46.950",
        "end": "03:50.550",
        "original": "え、でも悪魔なんか、結構マリンは小悪魔系で売ってるんで",
        "english": "But as for being a devil, Marine is already marketed as a little devil type,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:50.600",
        "end": "03:53.600",
        "original": "かなりシナジーあるかなって！",
        "english": "so I think there's a lot of synergy!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:53.650",
        "end": "03:56.800",
        "original": "だってぺこらも小悪魔系で売ってるからシナジー...",
        "english": "Well, Pekora is also marketed as a little devil, so synergy...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:56.850",
        "end": "03:58.700",
        "original": "お前は悪魔鳥だよ、悪魔鳥！",
        "english": "You're a devil bird, a devil bird!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:58.750",
        "end": "04:00.600",
        "original": "小悪魔...",
        "english": "Little devil...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:01.050",
        "end": "04:03.500",
        "original": "なんか、そんなの...",
        "english": "Something like that...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:03.550",
        "end": "04:05.450",
        "original": "うぉーーー！",
        "english": "Wooooh!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:05.500",
        "end": "04:07.750",
        "original": "変な悪魔いかない？",
        "english": "Isn't there a weird devil?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:07.800",
        "end": "04:09.150",
        "original": "嫌な奴だもの。",
        "english": "What a nuisance.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:09.200",
        "end": "04:11.850",
        "original": "天使と悪魔、どっちが好き、君たち？",
        "english": "Which do you guys like better, angels or devils?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:11.900",
        "end": "04:12.750",
        "original": "あ、確かに！",
        "english": "Oh, true!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:12.800",
        "end": "04:15.150",
        "original": "じゃあ「はい」で言ってもらえば、「天使の人」って言って...",
        "english": "Then let's have them respond with \"Yes\", for example when I say \"those who like angels\"...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:15.200",
        "end": "04:17.300",
        "original": "え、ペンライト！",
        "english": "Um, penlights!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:17.350",
        "end": "04:18.900",
        "original": "ペンライトの色とかあったかな？",
        "english": "Were there specific penlight colors?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:18.950",
        "end": "04:20.550",
        "original": "白と赤！",
        "english": "White and red!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:20.600",
        "end": "04:21.400",
        "original": "悪魔！",
        "english": "Devil!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:21.450",
        "end": "04:23.700",
        "original": "じゃあ、悪魔派は赤！",
        "english": "Then, for the devil faction, use red!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:23.750",
        "end": "04:25.750",
        "original": "赤。天使派は白！",
        "english": "Red. For the angel faction, white!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:25.800",
        "end": "04:26.550",
        "original": "白。の方！",
        "english": "White. That's the one!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:26.600",
        "end": "04:27.700",
        "original": "じゃあ行くか！",
        "english": "Let's go then!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:27.750",
        "end": "04:30.150",
        "original": "じゃあ皆さん変えてください！",
        "english": "Everyone, please change your colors!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:30.200",
        "end": "04:31.950",
        "original": "掲げてください！",
        "english": "Hold them up!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:32.000",
        "end": "04:34.900",
        "original": "あ、でも結構いい感じに割れてる！",
        "english": "Oh, it's divided pretty evenly!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:35.000",
        "end": "04:36.700",
        "original": "若干赤が多い？",
        "english": "Is red slightly more common?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:36.750",
        "end": "04:38.250",
        "original": "チェッ！",
        "english": "Tsk!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:38.300",
        "end": "04:40.400",
        "original": "あれ、悪魔の方が人気？",
        "english": "Huh, is the devil more popular?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:40.450",
        "end": "04:43.150",
        "original": "あ、でもなんか半々かも！",
        "english": "Oh, but it might be fifty-fifty!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:43.200",
        "end": "04:44.800",
        "original": "すげー割れてるね！",
        "english": "It's really split!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:44.850",
        "end": "04:46.400",
        "original": "ありがとー！",
        "english": "Thank you!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:46.450",
        "end": "04:49.150",
        "original": "え、じゃあ今日いいわね、悪魔な感じも！",
        "english": "Well, today is great, including the devilish vibe!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:49.200",
        "end": "04:51.650",
        "original": "これを見られて良かったね、ぺこら！",
        "english": "It was good to see this, Pekora!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:53.300",
        "end": "04:57.100",
        "original": "DAY1に引き続き、バンドも生演奏となってまーす！",
        "english": "Continuing from Day 1, the band is performing live!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:57.150",
        "end": "04:59.200",
        "original": "ありがとー！",
        "english": "Thank you!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:59.250",
        "end": "05:00.650",
        "original": "ありがとー！",
        "english": "Thank you!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      }
    ],
