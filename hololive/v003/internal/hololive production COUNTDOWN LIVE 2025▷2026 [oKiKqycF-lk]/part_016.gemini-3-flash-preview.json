        "type": "dialogue"
      },
      {
        "start": "02:37.000",
        "end": "02:40.000",
        "original": "Prism Melody",
        "english": "Prism Melody",
        "alignment_source": "visual_inference",
        "type": "on_screen_text"
      },
      {
        "start": "02:46.500",
        "end": "02:49.000",
        "original": "聞こえてた　何かが　始まるサイン",
