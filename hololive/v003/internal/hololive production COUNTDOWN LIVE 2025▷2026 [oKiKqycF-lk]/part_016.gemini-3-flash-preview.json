        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:49.000",
        "end": "02:51.800",
        "original": "集まって　気づけば　鼓動を奏でた",
        "english": "We gathered and realized we're playing a heartbeat.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:57.000",
        "end": "03:00.000",
        "original": "夢に見る　だけじゃもう　足りないでしょう？",
        "english": "Just dreaming isn't enough anymore, is it?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:00.000",
        "end": "03:03.000",
        "original": "君を待ってる　世界があるよ",
        "english": "There's a world out there waiting for you.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:08.500",
        "end": "03:11.200",
        "original": "楽しい予感にほら　飛び乗っちゃえばいい",
        "english": "Just jump onto that fun premonition.",
