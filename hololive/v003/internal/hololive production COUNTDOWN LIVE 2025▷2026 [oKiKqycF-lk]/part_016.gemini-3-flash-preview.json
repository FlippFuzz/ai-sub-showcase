        "type": "dialogue"
      },
      {
        "start": "03:11.200",
        "end": "03:14.300",
        "original": "ときめきは止められないから",
        "english": "Because this excitement cannot be stopped.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:19.400",
        "end": "03:22.000",
        "original": "運ぼう　連れて行くよ　光の真ん中",
        "english": "Let's go, I'll take you to the center of the light.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:22.000",
        "end": "03:25.000",
        "original": "夢の先へ",
        "english": "Beyond our dreams.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:25.000",
        "end": "03:28.000",
        "original": "羽ばたける　勇気は君の願い",
        "english": "The courage to fly is your wish.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:28.500",
        "end": "03:31.000",
        "original": "みんなで　繋いだ　この軌跡が",
        "english": "This trajectory we've connected together...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:31.000",
