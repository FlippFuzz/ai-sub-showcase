        "type": "dialogue"
      },
      {
        "start": "04:10.000",
        "end": "04:12.700",
        "original": "自分なり　道行く　僕らも旅",
        "english": "We're on a journey, going our own way.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:12.700",
        "end": "04:15.500",
        "original": "願いだけが　道標だよ",
        "english": "Our wishes are our guideposts.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:21.000",
        "end": "04:23.800",
        "original": "夢の色が変わっても　変わらないメロディ",
        "english": "Even if the color of dreams changes,\nthe melody remains the same.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:23.800",
        "end": "04:26.800",
        "original": "君のために　僕らのために",
        "english": "For you, and for us.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:32.000",
        "end": "04:34.500",
        "original": "歌おう　そうさきっと　僕らの軌跡は",
        "english": "Let's sing, our trajectory will surely...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:34.500",
        "end": "04:37.300",
        "original": "終わらないよ",
        "english": "...never end.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:37.300",
        "end": "04:40.500",
        "original": "涙さえ　きっかけに変えていこう",
        "english": "Let's turn even our tears into a new beginning.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:41.000",
