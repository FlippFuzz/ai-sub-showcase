        "original": "君と歩くことさ",
        "english": "Is walking with you",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:48.000",
        "end": "02:52.400",
        "original": "君と歩くことなんだ",
        "english": "Is walking with you",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
