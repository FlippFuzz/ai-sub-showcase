    "subtitles": [
      {
        "start": "00:00.000",
        "end": "00:01.800",
        "original": "せーの！チア！チア！",
        "english": "One, two! Cheer! Cheer!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:12.400",
        "end": "00:14.800",
        "original": "一生現場で、チア！",
        "english": "Cheering at the scene for life!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:29.000",
        "end": "00:32.000",
        "original": "はぁ、はぁ…やったー！",
        "english": "*Panting* We did it!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:33.500",
        "end": "00:35.000",
        "original": "みんなー！",
        "english": "Everyone!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:35.500",
        "end": "00:37.000",
        "original": "いぇーい！",
        "english": "Yay!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:40.500",
        "end": "00:42.500",
        "original": "ちょ、ちょっと安心しすぎたぺこ。",
        "english": "I-I'm a bit too relieved, peko.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:42.500",
        "end": "00:44.500",
        "original": "落ち着いて、落ち着いて。",
        "english": "Calm down, calm down.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:45.500",
        "end": "00:48.000",
        "original": "落ち着くために自己紹介しようってことで。",
        "english": "Let's do self-introductions to calm down.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:48.000",
        "end": "00:49.000",
        "original": "自己紹介ね、オッケー。",
        "english": "Self-introductions, okay.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:50.000",
        "end": "00:51.500",
        "original": "じゃあ、ぺこらから行きますよ！",
        "english": "Then, Pekora will go first!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:51.600",
        "end": "00:53.400",
        "original": "こんぺこ、こんぺこ、こんぺこ！",
        "english": "Konpeko, konpeko, konpeko!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:53.600",
        "end": "00:56.200",
        "original": "ホロライブ3期生の、兎田ぺこらっ…と！",
        "english": "Hololive 3rd Gen's Usada Pekora... tto!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:56.500",
        "end": "00:58.500",
        "original": "待てぺこって言わせてやれよ！",
        "english": "Wait, let them say \"peko\" too!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:58.500",
        "end": "01:00.500",
        "original": "言いたいんだって、確かに。",
        "english": "They want to say it, true.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:00.500",
        "end": "01:02.000",
        "original": "もう一回やってよ、もう一回。",
        "english": "Do it again, one more time.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:02.000",
        "end": "01:04.000",
        "original": "なんて言えばいいの？ぺこらは、じゃあ。",
        "english": "What should I say then, for Pekora?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:04.000",
        "end": "01:06.500",
        "original": "「こんぺこ、こんぺこ、こんぺこ」って言ったら、向こうも言いたいんだよ。",
        "english": "When you say \"Konpeko, konpeko, konpeko,\" they want to say it back.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:06.500",
        "end": "01:07.500",
        "original": "ああ、そういうことね。",
        "english": "Oh, I see.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:07.500",
        "end": "01:10.000",
        "original": "じゃあ、みんなやってくれますかー？",
        "english": "Then, will everyone do it for me?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:13.000",
        "end": "01:16.000",
        "original": "こんぺこ、こんぺこ、こんぺこー！",
        "english": "Konpeko, konpeko, konpeko!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:16.000",
        "end": "01:17.500",
        "original": "こんぺこー！",
        "english": "Konpeko!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:18.000",
        "end": "01:19.500",
        "original": "いいね！",
        "english": "Nice!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:20.500",
        "end": "01:24.000",
        "original": "ホロライブ3期生の兎田ぺこらっ、と！",
        "english": "Hololive 3rd Gen's Usada Pekora... tto!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:24.500",
        "end": "01:29.500",
        "original": "はい、じゃあフレアは「こんぬい」じゃなくて「はい、ダーリン」って言うから「はい、ハニー」って返してください。",
        "english": "Okay, so Flare will say \"Hi Darling\" instead of \"Kon-nui,\" so please return with \"Hi Honey.\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:32.400",
        "end": "01:34.000",
        "original": "はい、ダーリン！",
        "english": "Hi Darling!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:34.000",
        "end": "01:35.500",
        "original": "はい、ハニー！",
        "english": "Hi Honey!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:36.500",
        "end": "01:37.500",
        "original": "ありがとう！",
        "english": "Thank you!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:38.000",
        "end": "01:41.500",
        "original": "ホロライブ3期生の不知火フレアっ、と！",
        "english": "Hololive 3rd Gen's Shiranui Flare... tto!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:42.000",
        "end": "01:46.500",
        "original": "じゃあ団長は「牛丼は？」って言うんで「並盛りー！」って言ってください！",
        "english": "Then I'll say \"How's the beef bowl?\" so please say \"Standard size!\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:51.300",
        "end": "01:53.000",
        "original": "牛丼は？",
        "english": "How's the beef bowl?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:53.000",
        "end": "01:54.800",
        "original": "並盛りー！",
        "english": "Standard size!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:54.800",
        "end": "01:56.500",
        "original": "あーい、そうだよねー！",
        "english": "Aye, that's right!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:56.500",
        "end": "02:00.000",
        "original": "ホロライブ3期生の白銀ノエルっ、と！",
        "english": "Hololive 3rd Gen's Shirogane Noel... tto!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:00.500",
        "end": "02:05.500",
        "original": "君たち！今、もしかしてフレアのこと「ハニー」って言った？",
        "english": "You guys! Did you just call Flare \"Honey\"?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:05.500",
        "end": "02:07.000",
        "original": "言ってるー！お前らー！",
        "english": "They said it! You guys!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:07.500",
        "end": "02:09.000",
        "original": "浮気だー！",
        "english": "It's cheating!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:09.000",
        "end": "02:11.000",
        "original": "よろよろ。",
        "english": "*Staggers*",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:11.000",
        "end": "02:12.500",
        "original": "大丈夫？",
        "english": "Are you okay?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:12.500",
        "end": "02:15.500",
        "original": "団長のこと忘れてしまうなんて、君たち！",
        "english": "To think you'd forget about me, you guys!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:16.000",
        "end": "02:17.500",
        "original": "なんちゃって。",
        "english": "Just kidding.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:18.500",
        "end": "02:22.500",
        "original": "じゃあ、普通に「Ahoy」で行きますんで「Ahoy」って言ってくださいね。",
        "english": "Well, I'll just go with \"Ahoy,\" so please say \"Ahoy.\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:23.000",
        "end": "02:24.500",
        "original": "Ahoy!",
        "english": "Ahoy!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:24.500",
        "end": "02:27.500",
        "original": "Ahoy!",
        "english": "Ahoy!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:27.500",
        "end": "02:29.500",
        "original": "誰がアホや！",
        "english": "Who are you calling a fool!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:30.000",
        "end": "02:31.500",
        "original": "なんちゃって。",
        "english": "Just kidding.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:32.000",
        "end": "02:39.500",
        "original": "ホロライブ3期生、宝鐘海賊団船長の宝鐘マリンです！",
        "english": "Hololive 3rd Gen, Captain of the Houshou Pirates, Houshou Marin!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:45.000",
        "end": "02:47.500",
        "original": "せっかくだから、みんななんかアイドル口上みたいなの、ブラッシュアップしたやつやる？",
        "english": "Since we're here, why don't we do those idol slogans we brushed up?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:50.000",
        "end": "02:53.000",
        "original": "え、やろうよ！やろうよこれ！やるしかなくない？",
        "english": "Oh, let's do it! Let's do this! We have to, right?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:54.000",
        "end": "02:56.500",
        "original": "そう、配信でもやった、順番で。",
        "english": "Yeah, the ones we did on stream, in order.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:57.000",
        "end": "02:58.500",
        "original": "順番で行きましょう、順番で。",
        "english": "Let's go in order, in order.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:59.500",
        "end": "03:02.000",
        "original": "みんな覚えてるよね？ぺこらの口上。",
        "english": "Everyone remembers, right? Pekora's slogan.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:02.000",
        "end": "03:04.000",
        "original": "絶対覚えてねーぞ。",
        "english": "I'm sure they don't remember.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:04.000",
        "end": "03:07.000",
        "original": "覚えてるよね？ちゃんと。覚えてる人手挙げて！",
        "english": "You remember, right? For sure. Raise your hand if you remember!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:08.500",
        "end": "03:11.500",
        "original": "あ、でもそこそこ挙がってるよ！めっちゃ挙がってる！",
        "english": "Oh, but quite a few are raised! A lot are raised!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:12.500",
        "end": "03:15.500",
        "original": "全然挙がってないよ。全然覚えてねーって。",
        "english": "Not at all. They're saying they don't remember at all.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:16.000",
        "end": "03:18.500",
        "original": "じゃあ、今から覚えてくださいね。じゃあぺこらから行きますよ！",
        "english": "Well, learn it now. Then, Pekora will go first!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:19.500",
        "end": "03:28.000",
        "original": "ラビット・キャロット・キラッと登場！最強アイドルぺこらが来たぺこ！まだまだ続くよ、ぺこらストーリー！",
        "english": "Rabbit, Carrot, Kiratto arrival! The strongest idol Pekora has arrived, peko! The Pekora Story continues on and on!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:32.000",
        "end": "03:35.000",
        "original": "ちょっとフレアめっちゃ難しいんだけどさ、いけるかなこれ？",
        "english": "Flare's is really hard, but I wonder if we can do it?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:36.000",
        "end": "03:38.500",
        "original": "いけるいける！みんなも掛け声、大丈夫だよ。",
        "english": "We can do it! Everyone knows the calls, it'll be fine.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:40.000",
        "end": "03:43.000",
        "original": "これ、みんなにもコール＆レスポンスしてほしくて。",
        "english": "I want everyone to do a call & response for this.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:43.500",
        "end": "03:46.000",
        "original": "「準備は？」って言ったら「万端！」",
        "english": "When I say \"Ready?\", say \"Perfect!\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:46.500",
        "end": "03:49.500",
        "original": "「ホールは？」って聞くので「簡単！」って言ってください。",
        "english": "I'll ask \"The hall?\", so please say \"Easy!\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:50.000",
        "end": "03:53.000",
        "original": "手拍子「パンパン！」ステップ「簡単！」",
        "english": "Handclaps, \"clap clap!\" Steps, \"Easy!\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:55.500",
        "end": "03:58.500",
        "original": "「私は？」 「フレアー！」",
        "english": "\"I am?\" \"Flare!\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:58.500",
        "end": "04:00.500",
        "original": "めっちゃ難いな。",
        "english": "That's really hard.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:00.500",
        "end": "04:03.000",
        "original": "これ練習ね、覚えてください。",
        "english": "This is practice, so please remember it.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:06.500",
        "end": "04:09.500",
        "original": "こんぬい！準備は？",
        "english": "Kon-nui! Ready?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:09.500",
        "end": "04:11.500",
        "original": "万端！",
        "english": "Perfect!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:11.500",
        "end": "04:13.000",
        "original": "ホールは？",
        "english": "The hall?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
