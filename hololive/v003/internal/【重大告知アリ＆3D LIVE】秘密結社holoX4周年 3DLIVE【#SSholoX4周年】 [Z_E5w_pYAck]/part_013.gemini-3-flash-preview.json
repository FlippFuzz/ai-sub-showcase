    "subtitles": [
      {
        "start": "00:00.300",
        "end": "00:02.300",
        "original": "22時10分よりですね、",
        "english": "Starting at 10:10 PM,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:02.300",
