    "subtitles": [
      {
        "start": "00:01.200",
        "end": "00:05.400",
        "original": "みんな、一緒に歌ってくれてありがとう！",
        "english": "Everyone, thank you for singing along with us!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:06.500",
        "end": "00:09.500",
        "original": "いやー、よかったね。会場がね、一体になったって感じでね。",
        "english": "Wow, that was great. I really felt like we were one with the crowd.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
