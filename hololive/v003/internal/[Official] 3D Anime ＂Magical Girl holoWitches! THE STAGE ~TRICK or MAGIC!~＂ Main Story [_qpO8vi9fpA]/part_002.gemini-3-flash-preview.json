        "original": "吹切丸（ふぶきりまる）！",
        "english": "Fubukirimaru!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:54.300",
        "end": "03:55.700",
        "original": "ここは任せて、ミオ。",
        "english": "Leave this to us, Mio.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
