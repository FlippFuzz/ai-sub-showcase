        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:18.400",
        "end": "04:22.700",
        "original": "この手を差し伸べ、掴んで、握る。",
        "english": "Reach out this hand, seize, and hold tight.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:23.000",
        "end": "04:25.800",
        "original": "天音のホロ、魔法少女かなた！",
        "english": "The Holo of Amane, Magical Girl Kanata!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:27.500",
        "end": "04:30.300",
        "original": "みんなの願いを咲かせる祈り。",
        "english": "A prayer to make everyone's wishes bloom.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:30.500",
        "end": "04:33.400",
        "original": "みこのホロ、魔法少女みこ！",
        "english": "The Holo of Miko, Magical Girl Miko!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:35.000",
