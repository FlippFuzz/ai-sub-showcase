        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:41.000",
        "end": "02:43.500",
        "original": "君の瞳にキスして",
        "english": "Kiss your eyes",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:43.700",
