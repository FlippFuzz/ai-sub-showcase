    "subtitles": [
      {
        "start": "00:00.000",
        "end": "00:07.500",
        "original": "魔法少女ホロウィッチ！ THE STAGE TRICK or MAGIC!",
        "english": "Magical Girl holoWitches! THE STAGE ~TRICK or MAGIC!~",
        "alignment_source": "visual_inference",
        "type": "on_screen_text"
      },
      {
        "start": "00:08.500",
        "end": "00:10.500",
        "original": "トリック・オア・トリート！",
        "english": "Trick or Treat!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:10.900",
        "end": "00:13.900",
        "original": "みんな、盛り上がってるー！？",
        "english": "Everyone, are you excited?!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:14.300",
        "end": "00:18.400",
        "original": "ホロウィッチのオープニングアクト、どうだったー！？",
        "english": "How was the holoWitches' opening act?!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:20.500",
        "end": "00:24.900",
        "original": "ここからもっと、もっと盛り上げていくのら！",
        "english": "We're going to hype things up even more from here!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:25.300",
        "end": "00:28.000",
        "original": "みんなで一緒に楽しもうね！",
        "english": "Let's all enjoy it together!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:30.300",
        "end": "00:34.500",
        "original": "今日は我々ホロキャスの配信者だけじゃなく、",
        "english": "Today, we're joined by more than just us HoloCas streamers;",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:34.900",
        "end": "00:39.500",
        "original": "あの超人気歌手、カノンさんがゲストで来てくださってまーす！",
        "english": "the super popular singer Kanon-san is here as a guest!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:40.000",
        "end": "00:43.500",
        "original": "カノンさん、どうぞー！",
        "english": "Please welcome Kanon-san!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:44.500",
        "end": "00:48.300",
        "original": "トリック・オア・トリート。",
        "english": "Trick or Treat.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:48.800",
        "end": "00:54.000",
        "original": "みんな、今日は最後までよろしく。",
        "english": "Everyone, please enjoy yourselves until the end today.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:57.100",
        "end": "01:01.800",
        "original": "ひやー、まさか、あのカノンさんと同じステージに立てるなんて！",
        "english": "Whoa, I can't believe we're on the same stage as Kanon-san!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:02.300",
        "end": "01:05.100",
        "original": "いや本当、憧れですよ！",
        "english": "Truly, she's an idol to us!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:05.500",
        "end": "01:10.800",
        "original": "カノンさんの歌を聞くと、すっごくパワーもらえるのら！",
        "english": "Listening to Kanon-san's singing gives me so much power!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:11.200",
        "end": "01:15.500",
        "original": "そうそう！こんなに頂いちゃっていいんですか！？ってくらいね。",
        "english": "Right?! Like, \"is it okay to receive this much?!\"",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:15.800",
        "end": "01:18.500",
        "original": "うーん、めっちゃ元気出るよ！",
        "english": "Hmm, it's so energizing!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:18.700",
        "end": "01:21.000",
        "original": "お？",
        "english": "Oh?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:21.300",
        "end": "01:24.500",
        "original": "ありがとう。なんでもないから。",
        "english": "Thank you. It's nothing.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:27.100",
        "end": "01:31.900",
        "original": "次の曲はみんなも一緒に歌ってほしいのら！",
        "english": "We want everyone to sing along for the next song!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:32.400",
        "end": "01:36.500",
        "original": "君たち、遠慮しないで声出してね！声！",
        "english": "You guys, don't hold back, let's hear those voices! Voices!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:45.300",
        "end": "01:50.500",
        "original": "じょいふる\n作詞・作曲：水野良樹",
        "english": "Joyful\nLyrics/Composition: Yoshiki Mizuno",
        "alignment_source": "visual_inference",
        "type": "on_screen_text"
      },
      {
        "start": "02:10.000",
        "end": "02:12.800",
        "original": "君の声を聞かせて",
        "english": "Let me hear your voice",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:13.200",
        "end": "02:16.100",
        "original": "さあ 冒険してみない？",
        "english": "Now, shall we go on an adventure?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:16.500",
        "end": "02:19.100",
        "original": "楽しいこと始めよう",
        "english": "Let's start something fun",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:19.400",
        "end": "02:22.000",
        "original": "遊びたい 絶対 トトタイタイ",
        "english": "I want to play, definitely...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:22.200",
        "end": "02:24.500",
        "original": "あわない じょい と じょい と じょい",
        "english": "Joy and joy and joy",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:24.700",
        "end": "02:27.700",
        "original": "ポップな ベイベー",
        "english": "Pop baby",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:28.000",
        "end": "02:30.200",
        "original": "じょい と じょい と じょい",
        "english": "Joy and joy and joy",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:30.400",
        "end": "02:33.700",
        "original": "ハッピーな ピーポー",
        "english": "Happy people",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:34.500",
