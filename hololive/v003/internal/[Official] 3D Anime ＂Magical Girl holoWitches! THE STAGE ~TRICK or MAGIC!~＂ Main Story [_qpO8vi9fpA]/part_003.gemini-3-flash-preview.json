    "subtitles": [
      {
        "start": "00:00.600",
        "end": "00:02.900",
        "original": "凍りつくさなる純白の愛、",
        "english": "Pure white love like a frozen flower,",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "00:02.900",
        "end": "00:04.600",
        "original": "雪のホロ！",
        "english": "Snowy holo!",
        "alignment_source": "audio_tokens",
