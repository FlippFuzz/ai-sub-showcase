      {
        "start": "03:25.500",
        "end": "03:27.500",
        "original": "すごい！3個目いいよ！",
        "english": "Amazing! Third one is good!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:27.500",
        "end": "03:30.000",
        "original": "おー！思ったより上手い！",
        "english": "Oh! Better than I thought!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:30.000",
        "end": "03:31.000",
        "original": "上手いやん！",
        "english": "You're good!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:31.400",
        "end": "03:35.000",
        "original": "うまいよー！いやーこれ、これ、これはー！",
        "english": "You're good! Man, this, this, this one!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:37.300",
        "end": "03:39.500",
        "original": "全然余裕余裕。一つ目！",
        "english": "Totally easy, easy. First one!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:40.500",
        "end": "03:43.000",
        "original": "うますぎる！うまい上手い！まだ、まだ、まだ！",
        "english": "Too good! Skillful! More, more, more!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:44.200",
        "end": "03:47.500",
        "original": "どこ？どこどこどこ？右下、そこら辺！",
        "english": "Where? Where, where? Lower right, around there!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:47.500",
        "end": "03:49.500",
        "original": "下、下、下！どこにある？",
        "english": "Down, down, down! Where is it?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:49.800",
        "end": "03:51.000",
        "original": "どこだ？！",
        "english": "Where is it?!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:51.000",
        "end": "03:52.500",
        "original": "あれ？どこだ？",
        "english": "Huh? Where is it?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:54.000",
        "end": "03:55.500",
        "original": "なくなっちゃった...",
        "english": "It's gone...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:55.500",
        "end": "03:58.500",
        "original": "いや、なんか守護霊が...",
        "english": "No, it's like a guardian spirit...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:58.500",
        "end": "04:02.000",
        "original": "神様が手伝ってもらったのかも",
        "english": "Maybe God helped me out.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:02.300",
        "end": "04:04.200",
        "original": "まつり先輩ナイスショット！",
        "english": "Matsuri-senpai, nice shot!",
        "alignment_source": "visual_inference",
        "type": "on_screen_text"
      },
      {
        "start": "04:02.000",
        "end": "04:04.500",
        "original": "どこだ？！あれー？！",
        "english": "Where is it?! Huh?!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:05.400",
        "end": "04:07.500",
        "original": "なんかギリギリ滑り込みで、半分取ったー！",
        "english": "Somehow I barely made it and got half!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:07.500",
        "end": "04:10.000",
        "original": "やったー！クリアー！",
        "english": "Yay! Clear!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:10.800",
        "end": "04:12.800",
        "original": "Level 2",
        "english": "Level 2",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:13.500",
        "end": "04:15.500",
        "original": "あちらをご覧ください！",
        "english": "Please look over there!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:15.500",
        "end": "04:19.000",
        "original": "はい。動いてる！何これ？！",
        "english": "Okay. They're moving! What is this?!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:19.000",
        "end": "04:21.000",
        "original": "むちゃくちゃ。はい、頑張っていきましょう",
        "english": "This is crazy. Okay, let's do our best.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:22.400",
        "end": "04:24.000",
        "original": "じゃあ誰から行く？",
        "english": "So, who's going first?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:24.000",
        "end": "04:28.000",
        "original": "俺だ俺だ俺だ！私も行きたい！わー！",
        "english": "It's me, me, me! I want to go too! Whoa!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:28.000",
        "end": "04:30.500",
        "original": "難しそう...",
        "english": "Looks hard...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:30.800",
        "end": "04:33.500",
        "original": "もう行っちゃったから、じゃ、ラプラス様から行っちゃったからね",
        "english": "Since she already went, well, La+ Darknesss-sama went ahead.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:34.500",
        "end": "04:36.500",
        "original": "いいんだ。やったもん勝ちでやばい",
        "english": "It's fine. It's a free-for-all, crazy.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:36.500",
        "end": "04:39.000",
        "original": "ではいきましょう、ラプラス。いきますよ",
        "english": "Then let's go, La+. Here we go.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:39.400",
        "end": "04:42.300",
        "original": "3, 2, 1, Start!",
        "english": "3, 2, 1, Start!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:42.500",
        "end": "04:44.200",
        "original": "このゲームには 必勝法 がある",
        "english": "There is a winning strategy for this game",
        "alignment_source": "visual_inference",
        "type": "on_screen_text"
      },
      {
        "start": "04:42.500",
        "end": "04:44.200",
        "original": "このゲームには必勝法がある！",
        "english": "There's a winning strategy for this game!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:44.200",
        "end": "04:46.000",
        "original": "めっちゃ回っとるやん！速い速い！",
        "english": "You're spinning a lot! Fast, fast!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:46.500",
        "end": "04:48.500",
        "original": "当たったー！当たったー！",
        "english": "I hit it! I hit it!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:51.500",
        "end": "04:53.500",
        "original": "後ろから撃ってるのヤバいって",
        "english": "Shooting from behind is crazy.",
        "alignment_source": "visual_inference",
        "type": "on_screen_text"
      },
      {
        "start": "04:51.500",
        "end": "04:54.000",
        "original": "後ろから撃ってるのヤバいって",
        "english": "Shooting from behind is crazy.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:53.600",
        "end": "04:55.300",
        "original": "当たってないよ",
        "english": "Not hitting",
        "alignment_source": "visual_inference",
        "type": "on_screen_text"
      },
      {
        "start": "04:54.000",
        "end": "04:56.500",
        "original": "当たってないよ！当たってないよ！見て！",
        "english": "You're not hitting! You're not hitting! Look!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
