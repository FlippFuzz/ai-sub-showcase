        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:13.200",
        "end": "01:16.800",
        "original": "真っ白な雪のように",
        "english": "Like the pure white snow",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:16.800",
        "end": "01:19.400",
        "original": "どこまでも 素直な言葉",
        "english": "Honest words reaching everywhere",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:19.400",
        "end": "01:22.400",
        "original": "鉄の羽根 纏った",
        "english": "Clad in wings of steel",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:22.400",
        "end": "01:25.400",
        "original": "僕を動かしてく",
        "english": "They keep me moving forward",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:25.500",
        "end": "01:31.400",
        "original": "傷つくたびに 優しくなれる",
        "english": "Every time I'm hurt, I can become kinder",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:31.400",
        "end": "01:35.400",
        "original": "君のその笑顔だけ 守り抜きたい",
        "english": "I want to protect only your smile",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:35.400",
        "end": "01:40.000",
        "original": "願いはひとつ",
        "english": "That is my one and only wish",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:40.400",
        "end": "01:43.600",
        "original": "時を越え 刻まれた",
        "english": "Carved across time",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:43.600",
        "end": "01:46.800",
        "original": "悲しみの記憶",
        "english": "Memories of sadness",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:46.800",
        "end": "01:50.000",
        "original": "真っ直ぐに 受け止める",
        "english": "Accepting them head-on",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:50.000",
        "end": "01:53.200",
        "original": "君は光の戦士",
        "english": "You are a warrior of light",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:53.200",
        "end": "01:56.500",
        "original": "あの日 胸に灯った",
        "english": "Lit in my heart that day",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:56.500",
        "end": "01:59.800",
        "original": "永遠の炎",
        "english": "The eternal flame",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "01:59.800",
        "end": "02:03.400",
        "original": "深い闇 解き放って",
        "english": "Releasing the deep darkness",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "02:03.400",
