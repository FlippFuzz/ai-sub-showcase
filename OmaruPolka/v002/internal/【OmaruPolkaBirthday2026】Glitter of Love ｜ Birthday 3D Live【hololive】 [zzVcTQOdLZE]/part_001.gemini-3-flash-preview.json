      },
      {
        "start": "03:13.800",
        "end": "03:17.000",
        "original": "本当の僕を見せて",
        "english": "Show me the real me",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:17.300",
        "end": "03:20.500",
        "original": "吹き荒れる 切なさに",
