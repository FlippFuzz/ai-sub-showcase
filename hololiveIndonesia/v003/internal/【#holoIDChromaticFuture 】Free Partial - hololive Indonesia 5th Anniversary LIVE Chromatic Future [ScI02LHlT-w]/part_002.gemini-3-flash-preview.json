        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:32.500",
        "end": "03:35.800",
        "original": "Makasih banyak semuanya udah pada datang ke konser 5 tahun kita ya!",
        "english": "Thank you so much everyone for coming to our 5-year concert!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:36.500",
        "end": "03:39.500",
        "original": "Wah nggak berasa nggak sih udah 5 tahun aja?",
        "english": "Wow, doesn't it feel like it's already been 5 years?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:39.800",
        "end": "03:42.800",
        "original": "Kalau gitu kita mulai dari perkenalan diri dulu nggak sih?",
        "english": "If so, should we start with self-introductions?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:43.000",
        "end": "03:46.500",
        "original": "Mulai dari aku, aku!",
        "english": "Starting from me, me!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:51.300",
        "end": "03:53.800",
        "original": "Ah Mission Starto! Tatatata!",
        "english": "Ah Mission Start! Tatatata!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:54.200",
        "end": "03:57.800",
        "original": "Aku Vestia Zeta dari hololive Indonesia Gen 3. Nice to meet you!",
        "english": "I'm Vestia Zeta from hololive Indonesia Gen 3. Nice to meet you!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:03.500",
        "end": "04:05.000",
        "original": "Oke, next Kaela!",
        "english": "Okay, next Kaela!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:06.000",
        "end": "04:13.500",
        "original": "Kaela grinding every time, the blacksmith from hololive ID Gen 3. I'm Kaela Kovalskia. Nice to meet you all!",
        "english": "Kaela grinding every time, the blacksmith from hololive ID Gen 3. I'm Kaela Kovalskia. Nice to meet you all!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:18.000",
        "end": "04:19.500",
        "original": "Next next next, Kobo Kobo Kobo!",
        "english": "Next next next, Kobo Kobo Kobo!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:20.000",
        "end": "04:27.500",
        "original": "Bokobokobo Kobo Kanaeru at your service. Let me be your sun to shine your day. Ehe! Kobo-kan!",
