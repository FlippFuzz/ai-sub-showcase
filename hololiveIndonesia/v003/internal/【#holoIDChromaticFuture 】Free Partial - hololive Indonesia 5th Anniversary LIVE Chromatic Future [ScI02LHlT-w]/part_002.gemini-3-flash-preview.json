      },
      {
        "start": "03:12.300",
        "end": "03:24.500",
        "original": "Welcome to hololive Indonesia 5th Anniversary LIVE Chromatic Future!",
        "english": "Welcome to hololive Indonesia 5th Anniversary LIVE Chromatic Future!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:30.000",
        "end": "03:32.400",
        "original": "Wah gila gila gila!",
