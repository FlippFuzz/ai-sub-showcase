        "original": "守ってルーナイト",
        "english": "Protect me, Luna-knight",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:00.300",
        "end": "04:01.000",
        "original": "かまってくんないと",
        "english": "If you don't pay attention to me",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:01.200",
        "end": "04:02.800",
        "original": "ブラウニーにキャンディー",
        "english": "Brownies and candies",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:02.900",
        "end": "04:04.100",
        "original": "どれだけあってもね",
        "english": "No matter how many I have",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:04.200",
        "end": "04:06.500",
        "original": "君がいなきゃ だって",
        "english": "...it's no good without you!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:06.600",
        "end": "04:09.400",
        "original": "みんな 心して",
        "english": "Everyone, brace yourselves",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:09.500",
        "end": "04:10.700",
        "original": "捧げなさい！",
        "english": "Devote yourselves!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:10.800",
        "end": "04:11.900",
        "original": "姫であるぞ！",
        "english": "For I am the Princess!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:30.600",
        "end": "04:31.100",
        "original": "のらー！",
        "english": "Nora!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:31.300",
        "end": "04:32.600",
        "original": "みんな、およー！",
        "english": "Hello everyone!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:32.900",
        "end": "04:36.500",
        "original": "ほらライブ4期生、姫森ルーナなのののな。",
        "english": "I'm Himemori Luna from Hololive Gen 4, nano-nano-na.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:38.800",
        "end": "04:43.000",
        "original": "今日は、ルーナの生誕祭ライブ！",
        "english": "Today is Luna's Birthday Live!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:43.200",
        "end": "04:44.800",
        "original": "イエーイ！",
        "english": "Yay!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:45.300",
        "end": "04:48.400",
        "original": "みんな来てくれてありがとのら。",
        "english": "Thank you all for coming.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:48.800",
        "end": "04:52.000",
        "original": "今日のハッシュタグはこちら。",
        "english": "Today's hashtag is this one.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:52.200",
        "end": "04:53.000",
        "original": "デデン！",
        "english": "Ta-da!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:53.100",
        "end": "04:57.200",
        "original": "#姫森ルーナ生誕ライブ2025",
        "english": "#LunaRebirthDay2025",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:57.300",
        "end": "04:59.500",
        "original": "これでいっぱいツイートしてください。",
        "english": "Please tweet a lot with this.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      }
    ],
