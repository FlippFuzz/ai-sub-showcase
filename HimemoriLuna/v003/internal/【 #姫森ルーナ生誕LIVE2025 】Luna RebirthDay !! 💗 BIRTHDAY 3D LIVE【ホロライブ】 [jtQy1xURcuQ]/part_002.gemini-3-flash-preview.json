        "type": "dialogue"
      },
      {
        "start": "03:48.000",
        "end": "03:49.200",
        "original": "すごーい！",
        "english": "Amazing!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:49.200",
        "end": "03:51.300",
        "original": "姫、準備はOKですか？",
        "english": "Hime, are you ready?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:51.300",
        "end": "03:55.700",
        "original": "もちろん。出発進行なのらなー！",
        "english": "Of course. Full speed ahead!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:56.100",
        "end": "03:58.300",
        "original": "よし、飛びますよ！",
        "english": "All right, we're taking off!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:58.300",
        "end": "03:59.800",
        "original": "行くぞー！",
        "english": "Here we go!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:01.300",
        "end": "04:02.800",
        "original": "うわ！",
        "english": "Whoa!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:02.800",
        "end": "04:05.400",
        "original": "動いたー！わー、進むぞー！",
        "english": "It moved! Whoa, we're moving!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:08.500",
        "end": "04:12.300",
        "original": "すげー！この馬車、飛んでるのら！",
        "english": "Amazing! This carriage is flying!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:13.400",
        "end": "04:16.800",
        "original": "よし。よいしょ、よいしょ。こっち見てみよう。",
        "english": "All right. Heave-ho, heave-ho. Let's look this way.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:17.300",
        "end": "04:20.300",
        "original": "うわー！すごーい！",
        "english": "Wow! Amazing!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:20.300",
        "end": "04:24.400",
        "original": "星と雲がめちゃくちゃ綺麗な、のらよ。",
        "english": "The stars and clouds are so incredibly beautiful.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:26.500",
        "end": "04:29.800",
        "original": "うわー、眺め最高なのらね。",
        "english": "Wow, the view is the best.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:30.500",
        "end": "04:33.200",
        "original": "ガタンゴトン動いてます。",
        "english": "It's moving with a clatter.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:33.200",
        "end": "04:34.900",
        "original": "いいのら。",
        "english": "It's nice.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:34.900",
        "end": "04:37.400",
        "original": "こっちからも見てみるのらね。",
        "english": "Let's look from this side too.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:37.800",
        "end": "04:40.800",
        "original": "よいしょ、よいしょ。",
        "english": "Heave-ho, heave-ho.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:40.800",
        "end": "04:44.200",
        "original": "こっちもすごーい！眺め最高！",
        "english": "This side is amazing too! The best view!",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:44.200",
        "end": "04:47.800",
        "original": "おー、いい感じなのらな。",
        "english": "Oh, it feels good.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:48.200",
        "end": "04:50.800",
        "original": "高いなー、でもここ。",
        "english": "It's high up here, though.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:51.500",
        "end": "04:54.800",
        "original": "てかポリュナイトさん、このまま進んだら、",
        "english": "By the way, Polu-Knight-san, if we keep going like this...",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:54.800",
        "end": "04:58.200",
        "original": "目の前のデッケー雲とぶつかるのらけどさ。",
        "english": "...we're going to crash into that huge cloud in front of us.",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:58.200",
        "end": "04:59.800",
        "original": "大丈夫なのら？",
        "english": "Is it going to be okay?",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      }
    ],
    "model_name": "gemini-3-flash-preview"
  }
}