        "original": "君だけにそっと見せていたい",
        "english": "I want to show it only to you",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:21.600",
        "end": "03:24.800",
        "original": "心の中 瞳の奥",
        "english": "Inside my heart, deep in my eyes",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:24.900",
        "end": "03:28.200",
        "original": "そばにいてほしいよ",
        "english": "I want you to be by my side",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:28.300",
        "end": "03:32.100",
        "original": "恋のミラーボール 照らされて",
