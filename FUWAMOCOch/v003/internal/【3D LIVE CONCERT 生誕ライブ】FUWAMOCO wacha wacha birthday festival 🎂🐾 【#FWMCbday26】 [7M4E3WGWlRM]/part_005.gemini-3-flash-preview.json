        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:33.800",
        "end": "03:36.900",
        "original": "MY DARLIN' ねえ ヴィヴィッドな 恋しましょう",
        "english": "MY DARLIN', hey, let's have a vivid love",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:36.900",
        "end": "03:40.500",
        "original": "弾ける SEXY BEAUTY",
        "english": "Sparkling SEXY BEAUTY",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:40.600",
        "end": "03:43.700",
        "original": "生まれ変わって 甘い夢",
        "english": "Reborn into a sweet dream",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:43.800",
        "end": "03:48.800",
        "original": "ずっと 彩る MY LOVE FOR EVER",
        "english": "Always coloring MY LOVE FOR EVER",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:49.400",
        "end": "03:52.400",
        "original": "世界は変わる",
        "english": "The world changes",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "03:54.600",
        "end": "03:58.500",
        "original": "CHU-LU CHU-LU CHU-LU PA-YA-PA",
        "english": "CHU-LU CHU-LU CHU-LU PA-YA-PA",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:05.100",
        "end": "04:08.400",
        "original": "ドラマティックな 呪文で",
        "english": "With a dramatic spell",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:08.500",
        "end": "04:11.800",
        "original": "褪せないデジャヴ 見せつけたくて",
        "english": "I want to show you an unfading deja vu",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:11.900",
        "end": "04:15.200",
        "original": "カラフルな シーン ストーリー",
        "english": "A colorful scene, a story",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:15.300",
        "end": "04:18.600",
        "original": "心深く 刻み込む",
        "english": "Etched deep into my heart",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:18.700",
        "end": "04:21.800",
        "original": "小さな闇が訪れても",
        "english": "Even if a little darkness arrives",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:21.900",
        "end": "04:25.100",
        "original": "恋の呪文 唱えたなら",
