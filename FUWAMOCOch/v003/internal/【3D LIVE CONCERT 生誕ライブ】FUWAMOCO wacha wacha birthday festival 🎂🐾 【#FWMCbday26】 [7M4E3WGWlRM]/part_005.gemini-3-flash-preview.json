        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:25.200",
        "end": "04:28.500",
        "original": "ときめく果てない空",
        "english": "The fluttering, endless sky",
        "alignment_source": "audio_tokens",
        "type": "dialogue"
      },
      {
        "start": "04:28.600",
        "end": "04:32.500",
        "original": "星屑のシャワーが 降り注ぐ",
